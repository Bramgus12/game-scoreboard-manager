generator client {
  provider               = "prisma-client"
  output                 = "./generated/prisma"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
}

datasource db {
  provider = "postgresql"
}

model boerenbridge_game {
  id                       String                @id @db.Uuid
  created_at               DateTime              @db.Timestamptz(6)
  updated_at               DateTime              @db.Timestamptz(6)
  current_round            Int
  points_per_correct_guess Int
  scoreboard_id            String                @db.Uuid
  scoreboard               scoreboard            @relation(fields: [scoreboard_id], references: [id], onDelete: NoAction, map: "boerenbridge_game_scoreboard_id_foreign")
  boerenbridge_player      boerenbridge_player[]
}

model boerenbridge_player {
  id                 String               @id @db.Uuid
  created_at         DateTime             @db.Timestamptz(6)
  updated_at         DateTime             @db.Timestamptz(6)
  name               String               @db.VarChar(255)
  game_id            String               @db.Uuid
  boerenbridge_game  boerenbridge_game    @relation(fields: [game_id], references: [id], onDelete: NoAction, map: "boerenbridge_player_game_id_foreign")
  boerenbridge_round boerenbridge_round[]
}

model boerenbridge_round {
  id                  String              @id @db.Uuid
  created_at          DateTime            @db.Timestamptz(6)
  updated_at          DateTime            @db.Timestamptz(6)
  round_number        Int
  guess               Int
  is_correct          Boolean
  player_id           String              @db.Uuid
  penalty_points      Int
  boerenbridge_player boerenbridge_player @relation(fields: [player_id], references: [id], onDelete: NoAction, map: "boerenbridge_round_player_id_foreign")
}

model klaverjas_round {
  id                String         @id @db.Uuid
  created_at        DateTime       @db.Timestamptz(6)
  updated_at        DateTime       @db.Timestamptz(6)
  round_number      Int
  points            Int
  fame              Int
  is_pit            Boolean
  is_wet            Boolean
  klaverjas_team_id String         @db.Uuid
  is_going          Boolean
  klaverjas_team    klaverjas_team @relation(fields: [klaverjas_team_id], references: [id], onDelete: NoAction, map: "klaverjas_round_klaverjas_team_id_foreign")
}

model klaverjas_team {
  id              String            @id @db.Uuid
  created_at      DateTime          @db.Timestamptz(6)
  updated_at      DateTime          @db.Timestamptz(6)
  type            team_type
  name            String            @db.VarChar(255)
  scoreboard_id   String            @db.Uuid
  klaverjas_round klaverjas_round[]
  scoreboard      scoreboard        @relation(fields: [scoreboard_id], references: [id], onDelete: NoAction, map: "klaverjas_team_scoreboard_id_foreign")
}

model scoreboard {
  id                String              @id @db.Uuid
  created_at        DateTime            @db.Timestamptz(6)
  updated_at        DateTime            @db.Timestamptz(6)
  scoreboard_name   String              @db.VarChar(255)
  user_id           String              @db.Uuid
  game_type         game_type
  boerenbridge_game boerenbridge_game[]
  klaverjas_team    klaverjas_team[]
  mahjong_game      mahjong_game[]
  user              user                @relation(fields: [user_id], references: [id], onDelete: NoAction, map: "scoreboard_user_id_foreign")
}

model mahjong_game {
  id             String           @id @db.Uuid
  created_at     DateTime         @db.Timestamptz(6)
  updated_at     DateTime         @db.Timestamptz(6)
  scoreboard_id  String           @db.Uuid
  points_limit   Int
  hand_limit     Int
  rule_profile   mahjong_ruleset
  scoreboard     scoreboard       @relation(fields: [scoreboard_id], references: [id], onDelete: NoAction, map: "mahjong_game_scoreboard_id_foreign")
  mahjong_hand   mahjong_hand[]
  mahjong_player mahjong_player[]
}

model mahjong_player {
  id                         String        @id @db.Uuid
  created_at                 DateTime      @db.Timestamptz(6)
  updated_at                 DateTime      @db.Timestamptz(6)
  game_id                    String        @db.Uuid
  name                       String        @db.VarChar(255)
  seat_index                 Int
  mahjong_game               mahjong_game  @relation(fields: [game_id], references: [id], onDelete: NoAction, map: "mahjong_player_game_id_foreign")
  discarded_hands            mahjong_hand[] @relation("mahjong_discarder")
  won_hands                  mahjong_hand[] @relation("mahjong_winner")

  @@unique([game_id, seat_index], map: "mahjong_player_game_id_seat_index_unique")
}

model mahjong_hand {
  id                    String           @id @db.Uuid
  created_at            DateTime         @db.Timestamptz(6)
  updated_at            DateTime         @db.Timestamptz(6)
  game_id               String           @db.Uuid
  hand_number           Int
  prevailing_wind       mahjong_wind
  win_type              mahjong_win_type
  winner_player_id      String?          @db.Uuid
  discarded_by_player_id String?         @db.Uuid
  winner_points         Int
  is_limit_hand         Boolean
  mahjong_game          mahjong_game     @relation(fields: [game_id], references: [id], onDelete: NoAction, map: "mahjong_hand_game_id_foreign")
  discarded_by_player   mahjong_player?  @relation("mahjong_discarder", fields: [discarded_by_player_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mahjong_hand_discarded_by_player_id_foreign")
  winner_player         mahjong_player?  @relation("mahjong_winner", fields: [winner_player_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mahjong_hand_winner_player_id_foreign")

  @@unique([game_id, hand_number], map: "mahjong_hand_game_id_hand_number_unique")
}

model user {
  id          String       @id @db.Uuid
  created_at  DateTime     @db.Timestamptz(6)
  updated_at  DateTime     @db.Timestamptz(6)
  external_id String       @db.VarChar(255)
  first_name  String       @db.VarChar(255)
  last_name   String       @db.VarChar(255)
  email       String       @db.VarChar(255)
  scoreboard  scoreboard[]
}

enum game_type {
  boerenbridge
  klaverjas
  mahjong
}

enum mahjong_wind {
  east
  south
  west
  north
}

enum mahjong_win_type {
  self_draw
  discard
  remise
}

enum mahjong_ruleset {
  nts_2002_2019_v1
}

enum team_type {
  us
  them
}
